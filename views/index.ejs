<section class="gamer-contact" id="contact">

  <!-- LEFT CONTENT -->
  <div class="contact-left">
    <p class="section-mini">CONTACT</p>

    <h2>Ready To Build?</h2>

    <p>
      Have an exciting project, internship opportunity or creative idea?
      Send me a message and let’s build something powerful, clean and futuristic.
    </p>

    <div class="contact-status">
      <span></span>
      Developer Online
    </div>
  </div>

  <!-- RIGHT FORM -->
  <form
    class="gamer-form"
    id="contactForm"
    action="/contact"
    method="POST"
    novalidate
  >

    <!-- Honeypot Spam Protection -->
    <div class="honeypot-field" aria-hidden="true">
      <label for="website">Website</label>

      <input
        type="text"
        id="website"
        name="website"
        tabindex="-1"
        autocomplete="off"
      >
    </div>

    <!-- Name -->
    <div class="input-box">
      <input
        type="text"
        id="contactName"
        name="name"
        placeholder=" "
        minlength="2"
        maxlength="50"
        autocomplete="name"
        required
      >

      <label for="contactName">Your Name</label>
      <small class="field-error"></small>
    </div>

    <!-- Email -->
    <div class="input-box">
      <input
        type="email"
        id="contactEmail"
        name="email"
        placeholder=" "
        maxlength="120"
        autocomplete="email"
        required
      >

      <label for="contactEmail">Your Email</label>
      <small class="field-error"></small>
    </div>

    <!-- Phone -->
    <div class="input-box">
      <input
        type="tel"
        id="contactPhone"
        name="phone"
        placeholder=" "
        maxlength="15"
        inputmode="tel"
        autocomplete="tel"
      >

      <label for="contactPhone">Your Phone No.</label>
      <small class="field-error"></small>
    </div>

    <!-- Subject -->
    <div class="input-box">
      <input
        type="text"
        id="contactSubject"
        name="subject"
        placeholder=" "
        minlength="3"
        maxlength="100"
        autocomplete="off"
      >

      <label for="contactSubject">Subject</label>
      <small class="field-error"></small>
    </div>

    <!-- Message -->
    <div class="input-box message-box">
      <textarea
        id="contactMessage"
        name="message"
        placeholder=" "
        minlength="10"
        maxlength="1000"
        required
      ></textarea>

      <label for="contactMessage">Your Message</label>
      <small class="field-error"></small>

      <span class="character-counter">
        <b id="messageCount">0</b>/1000
      </span>
    </div>

    <!-- Submit Button -->
    <button type="submit" id="contactSubmitBtn">
      <span>SEND MESSAGE</span>
      <i class="fa-solid fa-paper-plane"></i>
    </button>

    <!-- Server Response -->
    <div
      class="form-response"
      id="formResponse"
      role="status"
      aria-live="polite"
    ></div>

  </form>
 <!-- =================================
     CONTACT SUCCESS TERMINAL
================================== -->

<div class="transmission-overlay" id="transmissionOverlay">
  <div class="transmission-scanlines"></div>

  <div class="transmission-terminal">
    <div class="transmission-header">
      <div class="terminal-dots">
        <span></span>
        <span></span>
        <span></span>
      </div>

      <p>SECURE-MESSAGE-TRANSMISSION.exe</p>

      <button
        type="button"
        class="terminal-close"
        id="terminalClose"
        aria-label="Close transmission window"
      >
        ×
      </button>
    </div>

    <div class="transmission-body">
      <pre id="transmissionText"></pre>

      <div class="transmission-progress">
        <div id="transmissionBar"></div>
      </div>

      <div class="transmission-percentage">
        <span id="transmissionPercent">0%</span>
      </div>

      <div class="transmission-success" id="transmissionSuccess">
        <div class="success-icon">
          <i class="fa-solid fa-check"></i>
        </div>

        <h3>MESSAGE DELIVERED</h3>

        <p>
          Your transmission has been received successfully.
          I will connect with you soon.
        </p>

        <button type="button" id="terminalDoneBtn">
          RETURN TO PORTFOLIO
        </button>
      </div>
    </div>
  </div>
</div>
